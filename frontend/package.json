  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "dev": "concurrently \"npm start\" \"cd ../backend && python3 -m venv venv && source venv/bin/activate && pip install -r requirements.txt && python3 app.py\"",
